# API keys for BriefLoop
# Copy this file to .env and fill in keys for features you enable.
# Only enabled providers require their key.
# Never commit .env to version control.

# ── Web search backends (choose one in sources.yaml) ──
# Tavily — fast AI search (default) — https://tavily.com
TAVILY_API_KEY=
# Exa — deep research, papers, filings — https://exa.ai
EXA_API_KEY=
# Brave — independent web index — https://brave.com/search/api
BRAVE_SEARCH_API_KEY=
# Firecrawl — search + full-text crawl — https://firecrawl.dev
FIRECRAWL_API_KEY=
# Serper — Google SERP — https://serper.dev
SERPER_API_KEY=

# ── News API ──
# NewsAPI.org — https://newsapi.org/register
NEWSAPI_API_KEY=

# ── Document parsing ──
# MinerU premium remote API — https://mineru.net -> Personal Center -> API Token
MINERU_API_TOKEN=
